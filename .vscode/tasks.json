{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Chat: Host Endpoint",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "${workspaceFolder}/main.py",
        "host",
        "--port",
        "9000",
        "--name",
        "alice"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Chat: Join Endpoint",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "${workspaceFolder}/main.py",
        "join",
        "--host",
        "127.0.0.1",
        "--port",
        "9000",
        "--name",
        "bob"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "FastAPI Deploy",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/fastapi",
      "args": [
        "deploy"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": false
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Chat: Relay Endpoint (Alice)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "${workspaceFolder}/main.py",
        "relay",
        "--url",
        "wss://ogham-chat.fastapicloud.dev/api/v1/ws",
        "--name",
        "alice"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "relay-chat",
        "focus": false,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Chat: Relay Endpoint (Bob)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "${workspaceFolder}/main.py",
        "relay",
        "--url",
        "wss://ogham-chat.fastapicloud.dev/api/v1/ws",
        "--name",
        "bob"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "relay-chat",
        "focus": false,
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
